{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": ["config:recommended", "schedule:monthly", ":semanticCommitTypeAll(chore)"],
    "packageRules": [{ "matchManagers": ["*"], "groupName": "{{{manager}}}" }],
    "separateMajorMinor": false,
    "rangeStrategy": "bump"
}
